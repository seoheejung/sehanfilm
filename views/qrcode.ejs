<%- include('partials/header.ejs'); %>
<body>
    <div class="parent-container">
        <a href='/' class="logo-text">2026 동아리 박람회</a>

        <!-- 결과 영역 -->
        <div class="result-container">
            <!-- 합성 이미지 카드 -->
            <div class="result-card preview-card">
                <div class="preview-image-wrap">
                    <img src="<%= imageUrl %>" class="photo" alt="Merged Image">
                </div>
            </div>

            <!-- QR 안내 카드 -->
            <div class="result-card qr-card">
                <p class="result-desc">
                    QR코드를 스캔하면<br>
                    Google Drive 다운로드 페이지로 이동합니다.
                </p>

                <!-- QR 코드가 렌더링될 영역 -->
                <div id="qr-code" class="qr-code"></div>

                <a href="/" class="back-link">돌아가기</a>
            </div>
        </div>

    </div>

    <script>
        // 페이지 로드 후 QR 코드 생성
        window.onload = function () {
            // 서버에서 넘겨준 Google Drive 다운로드 URL
            const googleUrl = "<%= googleUrl %>";

            // QR 코드가 들어갈 DOM 요소
            const qrCodeDiv = document.getElementById('qr-code');

            // Drive 링크가 없으면 오류 문구 출력
            if (!googleUrl) {
                qrCodeDiv.textContent = 'Google Drive 링크가 없습니다.';
                return;
            }

            // Google Drive 링크를 QR 이미지로 변환
            QRCode.toDataURL(googleUrl, function (err, url) {
                // QR 생성 실패 시 안내 문구 출력
                if (err) {
                    console.error(err);
                    qrCodeDiv.textContent = 'QR 코드를 생성할 수 없습니다.';
                }

                // 정상 생성 시 이미지 DOM 추가
                else {
                    const img = document.createElement('img');
                    img.src = url;
                    qrCodeDiv.appendChild(img);
                }
            });
        };
    </script>
</body>
</html>