<%- include('partials/header.ejs'); %>
<body>
    <div class="parent-container">
        <a href='/' class="logo-text">2026 동아리 박람회</a>

        <!-- 서버 1회 인증 상태 표시 -->
        <div style="margin-bottom: 16px; text-align: center;">
            <% if (!isGoogleDriveAuthorized) { %>
                <span class="main-text" style="font-size: 18px; color: #ff9800;">
                    Google Drive 1회 인증 필요
                </span>

                <div style="margin-top: 10px;">
                    <a href="/auth/google/start">
                        <button>Google Drive 연결하기</button>
                    </a>
                </div>
            <% } %>
        </div>

        <div class="frame-choice" id="frame-choice">
            <div class="guide-container">

                <!-- 메인 설명 카드 -->
                <div class="guide-card">
                    <div class="guide-title">
                        동박 프레임 블렌딩
                    </div>

                    <div class="guide-desc">
                        브랜딩 팀에서 제작한 동박 프레임으로<br>
                        우리들의 케미를 <span class="highlight">'블렌딩'</span> 해보세요.
                    </div>

                    <div class="guide-steps">
                        <div class="step">
                            <div class="step-index">1</div>
                            <div class="step-text">
                                <strong>Blend</strong><br>
                                친구들과 케미샷 촬영
                            </div>
                        </div>

                        <div class="step">
                            <div class="step-index">2</div>
                            <div class="step-text">
                                <strong>Share</strong><br>
                                인스타 스토리 업로드
                            </div>
                        </div>

                        <div class="step">
                            <div class="step-index">3</div>
                            <div class="step-text">
                                <strong>Tag</strong><br>
                                @sehan.youth 태그
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 카메라 안내 -->
                <div class="camera-guide">
                    촬영 버튼을 누르면 타이머 후 자동 촬영됩니다.<br>
                    리모컨은 <span class="highlight">A 버튼</span>을 눌러 촬영하세요.
                </div>
            </div>

            <!-- 프레임 -->
            <div class="frame">
                <img
                    src="/image/dongbak_shots/sample_small.png"
                    alt="sample_small"
                    width="60"
                    class="frame-select"
                    data-value="dongbak_shots"
                >
            </div>
        </div>

        <!-- 카메라 UI -->
        <div class="camera-ui" style="display: none;">
            <video id="webcam" autoplay playsinline></video>
            <canvas id="canvas"></canvas>
            <audio id="shutterSound" src="/lib/tfile.wav" preload="auto"></audio>
            <div class="controls" id="controls">
                <button id="capture">촬영</button>
            </div>
        </div>
    </div>
    <div id="loadingOverlay" class="loading-overlay" style="display: none;">
    
        <div class="loading-box">
            <div class="loading-spinner"></div>
            <div class="loading-text">사진 생성 중...</div>
        </div>
    </div>

    <script src="/js/webcam.js"></script>
    <script src="/js/capture.js"></script>
</body>
</html>