<%- include('partials/header.ejs'); %>
<body>
    <div class="parent-container">
        <a href='/' class="logo-text">sehanFilm</a>

        <!-- 서버 1회 인증 상태 표시 -->
        <div style="margin-bottom: 16px; text-align: center;">
            <% if (!isGoogleDriveAuthorized) { %>
                <span class="main-text" style="font-size: 18px; color: #ff9800;">
                    Google Drive 1회 인증 필요
                </span>

                <div style="margin-top: 10px;">
                    <a href="/auth/google/start">
                        <button>Google Drive 연결하기</button>
                    </a>
                </div>
            <% } %>
        </div>

        <!-- 프레임 선택 안내 -->
        <span class="main-text" id="frame-text">프레임을 선택해주세요.</span>

        <!-- 가로 프레임 -->
        <div class="frame-choice" id="frame-choice1">
            <div class="frame">
                <img
                    src="/image/c_film_frame_h.jpg"
                    alt="c_film_frame_h"
                    width="100"
                    class="frame-select"
                    data-value="film_frame_h"
                >
            </div>

            <div class="frame">
                <img
                    src="/image/c_lovekeykey_frame_h.jpg"
                    alt="c_lovekeykey_frame_h"
                    width="100"
                    class="frame-select"
                    data-value="lovekeykey_frame_h"
                >
            </div>

            <div class="frame">
                <img
                    src="/image/c_gosim_frame_h.jpg"
                    alt="c_gosim_frame_h"
                    width="100"
                    class="frame-select"
                    data-value="gosim_frame_h"
                >
            </div>
        </div>

        <!-- 세로 프레임 -->
        <div class="frame-choice" id="frame-choice2">
            <div class="frame">
                <img
                    src="/image/c_film_frame_v.jpg"
                    alt="c_film_frame_v"
                    width="100"
                    class="frame-select"
                    data-value="film_frame_v"
                >
            </div>

            <div class="frame">
                <img
                    src="/image/c_lovekeykey_frame_v.jpg"
                    alt="c_lovekeykey_frame_v"
                    width="100"
                    class="frame-select"
                    data-value="lovekeykey_frame_v"
                >
            </div>

            <div class="frame">
                <img
                    src="/image/c_gosim_frame_v.jpg"
                    alt="c_gosim_frame_v"
                    width="100"
                    class="frame-select"
                    data-value="gosim_frame_v"
                >
            </div>
        </div>

        <!-- 카메라 안내 -->
        <span class="main-text" id="camera-text" style="display: none;">
            촬영 버튼을 클릭하면 타이머로 자동 촬영되며,
            <br>
            리모컨은 "A" 버튼을 눌러 촬영하면 됩니다.
        </span>

        <!-- 카메라 UI -->
        <div class="camera-ui" style="display: none;">
            <video id="webcam" autoplay playsinline></video>
            <canvas id="canvas"></canvas>
            <audio id="shutterSound" src="/lib/tfile.wav" preload="auto"></audio>
            <div class="controls" id="controls">
                <button id="capture">촬영</button>
            </div>
        </div>

        <!-- 프레임 재선택 -->
        <div class="reset-frame" id="reset-frame" style="display: none;">
            <button id="select-frame">프레임 다시 선택하기</button>
        </div>

        <%- include('partials/footer.ejs'); %>
    </div>

    <script src="/js/webcam.js"></script>
    <script src="/js/capture.js"></script>
</body>
</html>